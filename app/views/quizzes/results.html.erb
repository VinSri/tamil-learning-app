<% content_for :title, "Quiz Results" %>

<div class="max-w-3xl mx-auto">
  <!-- Score Card -->
  <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 text-center mb-8">
    <div class="text-6xl mb-4">
      <%= @score.to_f / @total >= 0.9 ? '🏆' : @score.to_f / @total >= 0.7 ? '🎉' : @score.to_f / @total >= 0.5 ? '👍' : '📚' %>
    </div>
    <h1 class="text-4xl font-bold text-gray-800 mb-2"><%= @score %> / <%= @total %></h1>
    <p class="text-2xl font-semibold <%= @score.to_f / @total >= 0.7 ? 'text-green-600' : 'text-orange-500' %>">
      <%= (@score.to_f / @total * 100).round %>% Correct
    </p>
    <p class="text-gray-500 mt-3">
      <%= @score.to_f / @total >= 0.9 ? "Outstanding! You're a Tamil master!" :
          @score.to_f / @total >= 0.7 ? "Great job! Keep learning!" :
          @score.to_f / @total >= 0.5 ? "Good effort! Practice more to improve." :
          "Don't give up! Review the material and try again." %>
    </p>
  </div>

  <!-- Results Breakdown -->
  <h2 class="text-xl font-bold text-gray-800 mb-4">Review Answers</h2>
  <div class="space-y-4 mb-8">
    <% @results.each_with_index do |result, i| %>
      <div class="bg-white rounded-2xl p-6 shadow-sm border-2 <%= result[:correct] ? 'border-green-300' : 'border-red-200' %>">
        <div class="flex items-start gap-3 mb-4">
          <span class="<%= result[:correct] ? 'bg-green-500' : 'bg-red-500' %> text-white w-7 h-7 rounded-full flex items-center justify-center text-sm flex-shrink-0">
            <%= result[:correct] ? '✓' : '✗' %>
          </span>
          <p class="font-semibold text-gray-800"><%= result[:question].question %></p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 ml-10">
          <% result[:question].options.each_with_index do |option, opt_i| %>
            <div class="px-4 py-2 rounded-lg text-sm
              <%= opt_i == result[:question].correct_index ? 'bg-green-100 text-green-700 font-semibold border border-green-300' :
                  opt_i == result[:selected] && !result[:correct] ? 'bg-red-100 text-red-700 border border-red-300' :
                  'bg-gray-50 text-gray-500' %>">
              <%= ('A'..'Z').to_a[opt_i] %>. <%= option %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Actions -->
  <div class="flex justify-center gap-4">
    <%= link_to 'Try Again', quizzes_path(level: @level), class: "bg-red-700 text-white px-8 py-3 rounded-xl font-semibold hover:bg-red-800 transition" %>
    <%= link_to 'Back to Dashboard', dashboard_path, class: "border border-gray-300 text-gray-700 px-8 py-3 rounded-xl hover:border-red-300 transition" %>
  </div>
</div>
