<% content_for :title, "Dashboard" %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-800">Welcome back, <%= current_user.name %>!</h1>
  <p class="text-gray-500 mt-1">Keep learning. Every word counts.</p>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
    <div class="text-3xl font-bold text-brand"><%= @stats[:words_learned] %></div>
    <div class="text-gray-500 text-sm mt-1">Words Learned</div>
    <div class="mt-3 bg-gray-100 rounded-full h-2">
      <div class="bg-brand h-2 rounded-full transition-all" style="width: <%= [@stats[:words_learned].to_f / @stats[:total_words] * 100, 100].min.round %>%"></div>
    </div>
    <div class="text-xs text-gray-400 mt-1"><%= @stats[:words_learned] %> / <%= @stats[:total_words] %></div>
  </div>

  <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
    <div class="text-3xl font-bold text-brand"><%= @stats[:letters_learned] %></div>
    <div class="text-gray-500 text-sm mt-1">Letters Learned</div>
    <div class="mt-3 bg-gray-100 rounded-full h-2">
      <div class="bg-brand h-2 rounded-full transition-all" style="width: <%= [@stats[:letters_learned].to_f / @stats[:total_letters] * 100, 100].min.round %>%"></div>
    </div>
    <div class="text-xs text-gray-400 mt-1"><%= @stats[:letters_learned] %> / <%= @stats[:total_letters] %></div>
  </div>

  <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
    <div class="text-3xl font-bold text-gold"><%= @stats[:streak_days] %></div>
    <div class="text-gray-500 text-sm mt-1">Day Streak 🔥</div>
    <div class="text-xs text-gray-400 mt-4">Study daily to keep your streak!</div>
  </div>

  <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
    <div class="text-3xl font-bold text-brand"><%= @stats[:study_time] %></div>
    <div class="text-gray-500 text-sm mt-1">Minutes Studied</div>
    <div class="text-xs text-gray-400 mt-4">Total study time</div>
  </div>
</div>

<!-- Curriculum Path -->
<div class="flex items-center justify-between mb-4">
  <h2 class="text-xl font-bold text-gray-800">Your Learning Path</h2>
  <span class="text-sm text-gray-400">Step <%= @curriculum_position %> of <%= Curriculum.total %></span>
</div>

<!-- Progress bar -->
<div class="bg-gray-100 rounded-full h-2 mb-6">
  <div class="bg-red-700 h-2 rounded-full transition-all" style="width: <%= (@curriculum_position.to_f / Curriculum.total * 100).round %>%"></div>
</div>

<!-- Current step — prominent -->
<% current = @current_step %>
<% if current %>
  <div class="bg-red-700 text-white rounded-2xl p-6 mb-4 flex items-center justify-between shadow-md">
    <div>
      <div class="text-xs font-semibold uppercase tracking-widest opacity-75 mb-1">Up next</div>
      <div class="text-xl font-bold"><%= current[:title] %></div>
      <div class="text-sm opacity-80 mt-1"><%= current[:subtitle] %></div>
    </div>
    <%= link_to Curriculum.path_for(current, self), class: "bg-white text-red-700 font-semibold text-sm px-5 py-2 rounded-xl hover:opacity-90 transition shrink-0 ml-4" do %>
      Start &rarr;
    <% end %>
  </div>
<% end %>

<!-- Upcoming steps -->
<div class="space-y-2 mb-10">
  <% @curriculum_steps.each do |step| %>
    <%
      done    = step[:id] < @curriculum_position
      current = step[:id] == @curriculum_position
      locked  = step[:id] > @curriculum_position
    %>
    <% next if current %>

    <div class="bg-white rounded-xl px-5 py-3 border flex items-center gap-4
      <%= done ? 'border-green-200 opacity-70' : 'border-gray-100' %>">
      <div class="w-7 h-7 rounded-full flex items-center justify-center shrink-0 text-xs font-bold
        <%= done ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-400' %>">
        <%= done ? '✓' : step[:id] %>
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-semibold <%= done ? 'text-gray-400' : 'text-gray-700' %>"><%= step[:title] %></div>
        <div class="text-xs text-gray-400 truncate"><%= step[:subtitle] %></div>
      </div>
      <% if done %>
        <%= link_to "Review", Curriculum.path_for(step, self), class: "text-xs text-gray-400 hover:text-red-700" %>
      <% elsif !locked %>
        <%= link_to "Go →", Curriculum.path_for(step, self), class: "text-xs text-red-700 font-medium" %>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Achievements -->
<h2 class="text-xl font-bold text-gray-800 mb-4">Achievements</h2>
<div class="grid grid-cols-3 md:grid-cols-6 gap-3">
  <% @achievements.each do |achievement| %>
    <% unlocked = @unlocked_achievement_ids.include?(achievement.id) %>
    <div class="bg-white rounded-2xl p-4 text-center border <%= unlocked ? 'border-gold shadow-sm' : 'border-gray-100 opacity-50' %>">
      <div class="text-3xl mb-2"><%= achievement.icon %></div>
      <div class="text-xs font-semibold text-gray-700"><%= achievement.name %></div>
      <% if unlocked %>
        <div class="text-xs text-gold mt-1">Unlocked!</div>
      <% end %>
    </div>
  <% end %>
</div>
