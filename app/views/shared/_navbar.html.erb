<nav class="bg-white shadow-sm border-b border-gray-200">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <span class="text-2xl font-bold text-brand">தமிழ்</span>
          <span class="text-sm font-medium text-gray-600 hidden sm:block">கற்போம்</span>
        <% end %>
      </div>

      <!-- Nav Links (logged in) -->
      <% if user_signed_in? %>
        <div class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
          <%= link_to 'Dashboard', dashboard_path, class: "hover:text-brand #{current_page?(dashboard_path) ? 'text-brand' : ''}" %>
          <%= link_to 'Alphabet', letters_path, class: "hover:text-brand #{current_page?(letters_path) ? 'text-brand' : ''}" %>
          <%= link_to 'Vocabulary', words_path, class: "hover:text-brand #{current_page?(words_path) ? 'text-brand' : ''}" %>
          <%= link_to 'Grammar', grammar_lessons_path, class: "hover:text-brand #{current_page?(grammar_lessons_path) ? 'text-brand' : ''}" %>
          <%= link_to 'Reading', reading_passages_path, class: "hover:text-brand #{current_page?(reading_passages_path) ? 'text-brand' : ''}" %>
          <%= link_to 'Nigandu', nigandu_index_path, class: "hover:text-brand #{current_page?(nigandu_index_path) ? 'text-brand' : ''}" %>
          <%= link_to 'Quiz', quizzes_path, class: "hover:text-brand #{current_page?(quizzes_path) ? 'text-brand' : ''}" %>
        </div>

        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-brand text-white flex items-center justify-center text-sm font-bold">
            <%= current_user.name.first.upcase %>
          </div>
          <%= link_to 'Sign out', destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm text-gray-500 hover:text-brand" %>
        </div>
      <% else %>
        <div class="flex items-center gap-3">
          <%= link_to 'Sign in', new_user_session_path, class: "text-sm text-gray-600 hover:text-brand" %>
          <%= link_to 'Get Started', new_user_registration_path, class: "bg-flame text-white text-sm px-4 py-2 rounded-lg hover:opacity-90 transition" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
