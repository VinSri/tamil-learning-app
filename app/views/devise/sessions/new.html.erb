<% content_for :title, "Sign In" %>

<div class="min-h-screen flex items-center justify-center py-12">
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 w-full max-w-md">
    <div class="text-center mb-8">
      <div class="text-4xl font-bold text-red-700 mb-1">தமிழ் கற்போம்</div>
      <h2 class="text-2xl font-bold text-gray-800">Welcome back</h2>
      <p class="text-gray-500 text-sm mt-1">Sign in to continue learning</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:border-red-500",
              placeholder: "you@example.com" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full border border-gray-300 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:border-red-500",
              placeholder: "Password" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "rounded border-gray-300 text-red-700" %>
            <%= f.label :remember_me, class: "text-sm text-gray-600" %>
          </div>
        <% end %>

        <%= f.submit "Sign In", class: "w-full bg-red-700 text-white py-3 rounded-xl font-semibold hover:bg-red-800 transition cursor-pointer" %>
      </div>
    <% end %>

    <div class="text-center mt-6 text-sm text-gray-500">
      Don't have an account? <%= link_to "Sign up free", new_user_registration_path, class: "text-red-700 font-medium hover:underline" %>
    </div>
  </div>
</div>
