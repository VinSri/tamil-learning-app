<% content_for :title, "#{@entry.headword.sub(/\s*பெயர்\z/, '')} · நிகண்டு" %>

<div class="mb-4">
  <%= link_to "← நிகண்டு", nigandu_index_path(category: @entry.category), class: "text-sm text-gray-500 hover:text-red-700" %>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 mb-6">
  <div class="flex items-start justify-between flex-wrap gap-2 mb-2">
    <div class="text-5xl font-bold text-red-700 leading-tight">
      <%= @entry.headword.sub(/\s*பெயர்\z/, '') %>
    </div>
    <span class="text-sm text-gray-400 mt-3">சூத்திரம் #<%= @entry.sutra_number %></span>
  </div>

  <div class="text-sm text-gray-500 mb-6">
    <%= @category_labels[@entry.category] || @entry.category.capitalize %>
  </div>

  <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Synonyms</h2>
  <div class="flex flex-wrap gap-2">
    <% @entry.synonyms.each do |syn| %>
      <span class="bg-red-50 border border-red-100 text-red-800 text-base px-4 py-2 rounded-full font-medium">
        <%= syn.gsub(/[.\;]+\z/, '') %>
      </span>
    <% end %>
  </div>
</div>

<% if @linked_words_category %>
  <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 mb-6 flex items-center justify-between">
    <span class="text-sm text-amber-800">Study modern vocabulary for this theme</span>
    <%= link_to "Browse #{@linked_words_category.capitalize} →", words_path(category: @linked_words_category),
          class: "text-sm font-semibold text-amber-700 hover:underline" %>
  </div>
<% end %>

<% if @related.any? %>
  <h3 class="text-lg font-semibold text-gray-700 mb-3">More in <%= @category_labels[@entry.category] %></h3>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
    <% @related.each do |rel| %>
      <%= link_to nigandu_path(rel), class: "bg-white rounded-xl p-4 border border-gray-100 hover:border-red-300 transition block" do %>
        <div class="text-lg font-bold text-red-700 mb-1"><%= rel.headword.sub(/\s*பெயர்\z/, '') %></div>
        <div class="text-xs text-gray-400"><%= rel.synonyms.first(2).map { |s| s.gsub(/[.\;]+\z/, '') }.join(', ') %></div>
      <% end %>
    <% end %>
  </div>
<% end %>
