<% content_for :title, "Tamil Alphabet" %>
<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Tamil:wght@400;700&display=swap" rel="stylesheet">
  <style>.tamil-letter { font-family: 'Noto Sans Tamil', sans-serif; }</style>
<% end %>

<%
  total       = @vowels.count + @consonants.count
  learned_pct = total > 0 ? [(current_user.letters.count * 100 / total), 100].min : 0

  def letter_color(letter)
    case letter.kind
    when 'vowel'  then 'text-amber-500'
    when 'aytham' then 'text-gray-400'
    when 'consonant'
      case letter.letter_class
      when 'vallinam'  then 'text-red-400'
      when 'mellinam'  then 'text-teal-500'
      when 'idaiyinam' then 'text-violet-500'
      else 'text-gray-500'
      end
    else 'text-gray-500'
    end
  end

  sections = Letter::SECTIONS.map do |sec|
    stage_nums = Letter::STAGE_LABELS.select { |_, v| v[:section] == sec[:key] }.keys.select { |s| @stages.key?(s) }
    sec.merge(stage_nums: stage_nums)
  end.reject { |s| s[:stage_nums].empty? }
%>

<div class="w-full">

  <!-- Top bar: title + progress on one row (top-aligned); meta on its own row so nothing splits mid-sentence -->
  <div class="mb-8 space-y-2.5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
      <h1 class="text-xl font-bold tracking-tight text-gray-800 whitespace-nowrap sm:text-2xl">Tamil Alphabet</h1>
      <div class="flex items-center gap-3 w-full sm:w-52 md:w-56 shrink-0 sm:pt-0.5">
        <div class="flex-1 bg-gray-200 rounded-full h-2 min-w-0">
          <div id="progressBar" class="bg-green-400 h-2 rounded-full transition-all" style="width:<%= learned_pct %>%"></div>
        </div>
        <span class="text-xs text-gray-500 tabular-nums whitespace-nowrap shrink-0">
          <span id="progressCount"><%= current_user.letters.count %></span>/<%= total %>
        </span>
      </div>
    </div>
    <div class="flex items-center gap-x-3 text-xs text-gray-400 overflow-x-auto overscroll-x-contain pb-0.5 [-webkit-overflow-scrolling:touch] [scrollbar-width:thin]">
      <span class="whitespace-nowrap shrink-0">Teaching sequence · P1 → P2</span>
      <span class="text-gray-300 shrink-0" aria-hidden="true">·</span>
      <%= link_to letters_combinations_path, class: "text-red-700 hover:underline font-medium whitespace-nowrap shrink-0" do %>
        உயிர்மெய் Compounds →
      <% end %>
    </div>
  </div>

  <!-- Main: sidebar from lg up; letters stay first on narrow screens -->
  <div class="grid grid-cols-1 lg:grid-cols-[1fr,minmax(17.5rem,20rem)] gap-8 lg:gap-10 items-start">

    <!-- Letter grid -->
    <div class="space-y-10 min-w-0">
      <% sections.each do |sec| %>
        <div>
          <div class="flex items-baseline gap-2 mb-3">
            <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest"><%= sec[:title] %></h2>
            <span class="tamil-letter text-xs <%= sec[:color] %>"><%= sec[:tamil] %></span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3 sm:gap-4">
            <% sec[:stage_nums].each do |stage_num| %>
              <% stage_letters = @stages#[stage_num] %>
              <% meta          = Letter::STAGE_LABELS[stage_num] %>
              <div class="rounded-2xl p-3 sm:p-4 bg-gray-100/50">
                <div class="flex flex-wrap gap-2 justify-start">
                  <% stage_letters.each do |letter| %>
                    <% learned = @learned_ids.include?(letter.id) %>
                    <% color   = letter_color(letter) %>
                    <button
                      type="button"
                      class="letter-item relative flex flex-col items-center justify-center gap-0.5 w-14 h-14 rounded-xl bg-white text-center transition shadow-sm shadow-gray-900/5 hover:shadow-md hover:shadow-gray-900/10 active:scale-[0.97] focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-400 focus-visible:ring-offset-2"
                      data-id="<%= letter.id %>"
                      data-tamil="<%= letter.tamil %>"
                      data-roman="<%= letter.roman %>"
                      data-learned="<%= learned %>"
                      data-color="<%= color %>"
                      onclick="selectLetter(this)">
                      <span class="tamil-letter text-xl font-bold leading-none <%= learned ? 'text-green-500' : color %>"><%= letter.tamil %></span>
                      <span class="text-[9px] text-gray-400 leading-tight"><%= letter.roman %></span>
                      <span class="learned-check absolute top-0.5 right-1 text-[9px] text-green-500 font-bold <%= learned ? '' : 'invisible' %>">✓</span>
                    </button>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Practice panel (sticky on large screens; below nav) -->
    <div class="w-full max-w-md mx-auto lg:max-w-none lg:mx-0 lg:sticky lg:top-24 lg:self-start">

      <!-- Empty state -->
      <div id="emptyState" class="flex flex-col items-center justify-center min-h-[16rem] sm:min-h-[20rem] bg-gray-100/40 rounded-2xl text-center px-6 py-8 sm:py-10 shadow-inner shadow-gray-900/5">
        <p class="tamil-letter text-8xl sm:text-9xl text-gray-200 mb-3 leading-none">அ</p>
        <p class="text-sm text-gray-500">Select a letter to practise</p>
      </div>

      <!-- Letter detail -->
      <div id="letterDetail" class="hidden bg-white rounded-2xl shadow-lg shadow-gray-900/5 overflow-hidden ring-1 ring-gray-900/5">

        <!-- Hero -->
        <div class="flex flex-col items-center text-center sm:flex-row sm:items-end sm:text-left gap-3 sm:gap-4 px-5 pt-5 pb-4 border-b border-gray-100">
          <div id="detailLetter" class="tamil-letter text-7xl sm:text-8xl font-bold text-gray-800 leading-none select-none shrink-0"></div>
          <div class="sm:mb-1 flex-1 min-w-0 w-full">
            <div id="detailRoman" class="text-lg sm:text-xl text-gray-400 font-medium mb-2"></div>
            <div class="flex flex-wrap items-center justify-center sm:justify-start gap-x-3 gap-y-1">
              <button onclick="speak(currentLetter)"
                class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-gray-700 transition">
                🔊 Hear
              </button>
              <span class="text-gray-200">|</span>
              <button id="learnedBtn" onclick="toggleLearned()"
                class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-green-600 transition">
                Mark as learned
              </button>
            </div>
          </div>
        </div>

        <!-- Writing canvas -->
        <div class="px-5 pt-4">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Practice Writing</h3>
          <div class="relative border-2 border-gray-200 rounded-xl overflow-hidden bg-gray-50 aspect-[2/1] min-h-[140px]">
            <div id="ghostLetter" class="tamil-letter absolute inset-0 flex items-center justify-center text-6xl sm:text-8xl font-bold text-gray-100 select-none pointer-events-none"></div>
            <canvas id="writingCanvas" width="320" height="160" class="absolute inset-0 z-10 w-full h-full touch-none block"></canvas>
          </div>
          <button onclick="clearCanvas()" class="mt-1.5 text-xs text-gray-400 hover:text-gray-600 transition">Clear</button>
        </div>

        <!-- Example words -->
        <div class="px-5 pt-4 pb-5">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Example Words</h3>
          <div id="exampleWords" class="grid grid-cols-2 gap-2"></div>
          <p id="noWords" class="hidden text-sm text-gray-400 italic">No example words yet.</p>
        </div>

      </div>
    </div>

  </div>
</div>

<script>
  const csrfToken    = document.querySelector('meta[name="csrf-token"]').content;
  const totalLetters = <%= total %>;
  const allWords     = <%= raw @words_json %>;
  let currentLetterId = null;
  let currentLetter   = '';
  let canvas, ctx, isDrawing = false;

  function selectLetter(el) {
    document.querySelectorAll('.letter-item').forEach(i =>
      i.classList.remove('ring-2', 'ring-amber-400', 'ring-offset-1')
    );
    el.classList.add('ring-2', 'ring-amber-400', 'ring-offset-1');

    currentLetterId = el.dataset.id;
    currentLetter   = el.dataset.tamil;

    document.getElementById('emptyState').classList.add('hidden');
    document.getElementById('letterDetail').classList.remove('hidden');
    document.getElementById('detailLetter').textContent = currentLetter;
    document.getElementById('detailRoman').textContent  = el.dataset.roman;
    document.getElementById('ghostLetter').textContent  = currentLetter;

    updateLearnedBtn(el.dataset.learned === 'true');
    showExampleWords(currentLetter);
    initCanvas();
  }

  function toggleLearned() {
    fetch('/user_letters', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify({ letter_id: currentLetterId })
    })
    .then(r => r.json())
    .then(data => {
      updateLearnedBtn(data.learned);
      const item = document.querySelector(`.letter-item[data-id="${currentLetterId}"]`);
      if (item) {
        item.dataset.learned = data.learned;
        const check = item.querySelector('.learned-check');
        const span  = item.querySelector('.tamil-letter');
        if (check) check.classList.toggle('invisible', !data.learned);
        if (span) {
          span.className = span.className.replace(/text-\w+-\d+/g, '').trim();
          span.classList.add(data.learned ? 'text-green-500' : item.dataset.color);
        }
      }
      document.getElementById('progressCount').textContent = data.total;
      document.getElementById('progressBar').style.width =
        Math.min(Math.round(data.total * 100 / totalLetters), 100) + '%';
    });
  }

  function updateLearnedBtn(learned) {
    const btn = document.getElementById('learnedBtn');
    if (learned) {
      btn.className  = 'inline-flex items-center gap-1 text-sm text-green-600 transition';
      btn.textContent = '✓ Learned';
    } else {
      btn.className  = 'inline-flex items-center gap-1 text-sm text-gray-400 hover:text-green-600 transition';
      btn.textContent = 'Mark as learned';
    }
  }

  function showExampleWords(letter) {
    const base = letter.replace('்', '');
    const nonInitial = ['ங', 'ட', 'ண', 'ர', 'ல', 'ழ', 'ள', 'ற', 'ன'];
    const matches = nonInitial.includes(base)
      ? allWords.filter(w => w.tamil.includes(base))
      : allWords.filter(w => w.tamil.startsWith(base));
    const container = document.getElementById('exampleWords');
    const noWords   = document.getElementById('noWords');
    if (!matches.length) {
      container.innerHTML = '';
      noWords.classList.remove('hidden');
    } else {
      noWords.classList.add('hidden');
      container.innerHTML = matches.slice(0, 4).map(w => `
        <div class="bg-gray-50 rounded-lg p-2.5">
          ${w.emoji ? `<div class="text-xl mb-0.5">${w.emoji}</div>` : ''}
          <div class="tamil-letter text-lg font-bold text-gray-800 leading-snug">${w.tamil}</div>
          <div class="text-[11px] text-gray-400 mt-0.5">${w.english}</div>
        </div>
      `).join('');
    }
  }

  function initCanvas() {
    canvas = document.getElementById('writingCanvas');
    ctx    = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const r   = canvas.getBoundingClientRect();
    const w   = Math.max(1, Math.floor(r.width * dpr));
    const h   = Math.max(1, Math.floor(r.height * dpr));
    canvas.width  = w;
    canvas.height = h;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.lineWidth   = 4;
    ctx.lineCap     = 'round';
    ctx.lineJoin    = 'round';
    ctx.strokeStyle = '#B91C1C';
    clearCanvas();
    canvas.onmousedown  = e => { isDrawing = true; ctx.beginPath(); ctx.moveTo(pos(e).x, pos(e).y); };
    canvas.onmousemove  = e => { if (!isDrawing) return; ctx.lineTo(pos(e).x, pos(e).y); ctx.stroke(); };
    canvas.onmouseup    = () => isDrawing = false;
    canvas.onmouseleave = () => isDrawing = false;
    canvas.ontouchstart = e => { e.preventDefault(); isDrawing = true; ctx.beginPath(); ctx.moveTo(pos(e.touches[0]).x, pos(e.touches[0]).y); };
    canvas.ontouchmove  = e => { e.preventDefault(); if (!isDrawing) return; ctx.lineTo(pos(e.touches[0]).x, pos(e.touches[0]).y); ctx.stroke(); };
    canvas.ontouchend   = () => isDrawing = false;
  }

  function pos(e) {
    const r = canvas.getBoundingClientRect();
    return { x: e.clientX - r.left, y: e.clientY - r.top };
  }

  function clearCanvas() {
    if (!ctx || !canvas) return;
    ctx.save();
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.restore();
  }

  function speak(text) {
    const u = new SpeechSynthesisUtterance(text);
    u.lang = 'ta-IN';
    speechSynthesis.speak(u);
  }
</script>
